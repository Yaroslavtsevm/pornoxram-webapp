<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>PornoXram</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');
        body { background: linear-gradient(180deg, #1a0033 0%, #000000 100%); color: white; }
        .header-text { font-family: 'Playfair Display', serif; font-size: 2.8rem; background: linear-gradient(90deg, #ff00aa, #aa00ff, #00ffff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .nav-tab.active { border-bottom: 4px solid #ff00aa; color: #ff00aa; }
        .media-card:hover { transform: scale(1.05); box-shadow: 0 0 20px rgba(255, 0, 170, 0.6); }
    </style>
</head>
<body class="min-h-screen pb-24">
    <!-- Header и меню остаются почти без изменений (см. предыдущие версии) -->
    <!-- ... (скопируй header из предыдущего index.html) ... -->

    <div class="max-w-7xl mx-auto px-4 pt-6">
        <!-- Поиск -->
        <div class="mb-6">
            <input id="search-input" type="text" placeholder="Поиск..." 
                   class="w-full bg-zinc-900 rounded-3xl px-6 py-4 text-white outline-none"
                   onkeyup="if(event.key==='Enter') loadData()">
        </div>
        
        <div id="main-content"></div>
        
        <!-- Пагинация -->
        <div id="pagination" class="flex justify-center gap-4 mt-8"></div>
    </div>

    <!-- Спонсор кнопка, модалки, админка — оставь как было -->

    <script>
        // ... (остальной JS из предыдущей версии)

        let currentPage = 1;
        let currentSearch = '';

        async function loadData() {
            currentSearch = document.getElementById('search-input').value.trim();
            currentPage = 1;
            await fetchAndRender();
        }

        async function fetchAndRender() {
            const params = new URLSearchParams({
                page: currentPage,
                limit: 12,
                search: currentSearch
            });

            const endpoint = currentTab === 0 ? '/api/models' : '/api/categories';
            const res = await fetch(`${endpoint}?${params}`);
            const data = await res.json();

            // Рендер items (data.items вместо data)
            renderItems(data.items);
            renderPagination(data.total, data.pages);
        }

        function renderPagination(total, pages) {
            // Простая пагинация — добавь кнопки "Предыдущая / Следующая"
            let html = '';
            if (pages > 1) {
                html = `<button onclick="changePage(${currentPage-1})" ${currentPage===1?'disabled':''}>←</button>`;
                html += `<span class="px-6">${currentPage} / ${pages}</span>`;
                html += `<button onclick="changePage(${currentPage+1})" ${currentPage===pages?'disabled':''}>→</button>`;
            }
            document.getElementById('pagination').innerHTML = html;
        }

        function changePage(page) {
            if (page < 1) return;
            currentPage = page;
            fetchAndRender();
        }

        // В renderCurrentTab() замени на вызов fetchAndRender()
        // В showDetail() используй оригинальный url (Cloudinary сам оптимизирует)
        // Для cover и медиа можно добавить transformation вручную, например:
        // cover_url + '?w=600&q=auto'
    </script>
</body>
</html>
